# RobOS Environment Configuration
# Copy to .env and fill in your keys

# --- Web Scraping ---
# Used by research skills to crawl and extract web content
# Get yours at https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- OpenAI ---
# Used for Reddit and X/Twitter research via compatible endpoints
OPENAI_API_KEY=

# --- xAI (Grok) ---
# Used for X/Twitter search and trend analysis
# Get yours at https://console.x.ai
XAI_API_KEY=

# --- YouTube Data API ---
# Used for channel listings, video metadata, transcript retrieval
# Get yours at https://console.cloud.google.com
YOUTUBE_API_KEY=

# --- Google Gemini ---
# Used for image generation in content skills
# Get yours at https://aistudio.google.com
GEMINI_API_KEY=

# --- Dashboard ---
# Port for the Command Centre web interface
PORT=3001
