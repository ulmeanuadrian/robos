# ==============================================================================
# robOS — Environment Configuration
# ==============================================================================
# Acest fisier e TEMPLATE-ul. Copiaza-l in `.env` si populeaza ce folosesti.
# `.env` e gitignored (NU se urca in repo). `.env` e si fisier protejat in robOS
# (vezi AGENTS.md → "Fisiere protejate") — update-urile nu il suprascriu.
#
# REGULA: `.env` e SINGURA sursa de adevar pentru orice secret in robOS.
#         API keys, parole, tokeni, ID-uri — toate aici, nicaieri altundeva.
#
# robOS porneste si functioneaza FARA niciun secret. Cheile devin necesare doar
# cand rulezi un skill care le foloseste (ex: research-trending cere FIRECRAWL).
# Cand un skill nu gaseste cheia → graceful degradation (te avertizeaza).
#
# Bootstrap automat:
#   - La prima rulare, `node scripts/setup-env.js` copiaza acest fisier in `.env`.
#   - Pe masura ce instalezi skills noi care cer chei noi, slot-urile se adauga
#     automat aici si in `.env`.
#   - Le poti popula din dashboard: tab Sistem → Secrete (sau direct cu editor).
# ==============================================================================


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ CORE — robOS porneste cu zero din astea (toate au defaults rezonabile)     │
# └─────────────────────────────────────────────────────────────────────────────┘

# Port pentru Command Centre (dashboard web UI)
PORT=3001

# Bind address pentru dashboard. Default 127.0.0.1 (doar localhost = sigur).
# Schimba in 0.0.0.0 DOAR daca vrei acces din LAN — risc de compromis.
ROBOS_CENTRE_HOST=127.0.0.1

# Token de auth pentru endpoint-urile sensibile din dashboard (Authorization: Bearer).
# Auto-generat la prima rulare (`scripts/setup-env.js`). NU il sterge — daca-l pierzi,
# regenereaza-l si UI-ul te va deconecta. Format: 64 chars hex.
ROBOS_DASHBOARD_TOKEN=

# Checkpoint reminder threshold (minute) — dupa cat timp fara scriere in memoria
# zilei sa intervina hook-ul cu nudge-ul de checkpoint. Default 30.
ROBOS_CHECKPOINT_MIN=30

# Toggle hook checkpoint reminder. Setat 1 → dezactivat (nu recomandat).
ROBOS_CHECKPOINT_DISABLED=0

# Toggle hook activity capture (Stop hook care scrie in data/activity-log.ndjson).
# Setat 1 → dezactivat. Pierzi cross-session memory bridge.
ROBOS_ACTIVITY_DISABLED=0

# Loop Detector (PostToolUse hook — detecteaza cand modelul e blocat in loop)
# Setat 1 → dezactivat (nu se mai injecteaza warning cand acelasi tool call
# se repeta de N ori consecutiv). Default activ.
ROBOS_LOOP_DETECTOR_DISABLED=0

# Numarul de apeluri identice consecutive care declanseaza warning. Default 3.
# Al doilea warning (escalat) se emite la 2*threshold = 6 calls.
ROBOS_LOOP_DETECTOR_THRESHOLD=3

# Lista comma-separated de tool-uri care NU declanseaza warning. Util pentru
# tool-uri unde repetare identica e legitima (ex: TodoWrite cand state-ul e
# acelasi). Default: TodoWrite. Lasa gol pentru zero exemptions.
ROBOS_LOOP_DETECTOR_EXEMPT=TodoWrite

# Toggle hook note-candidates (Stop hook care detecteaza decizii/reguli in
# turn-ul curent + le pune in tabela note_candidates pentru review). Setat 1
# → dezactivat. Util daca nu folosesti second-brain notes feature.
ROBOS_CANDIDATES_DISABLED=0


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ SKILLS — chei API pentru skill-uri specifice. Lasa gol ce nu folosesti.    │
# └─────────────────────────────────────────────────────────────────────────────┘

# --- Web Scraping (Firecrawl) ---
# Folosit de: research-trending, research-competitors
# Cheia ta de la https://firecrawl.dev (free tier: 500 credits/lună)
FIRECRAWL_API_KEY=

# --- OpenAI ---
# Folosit de: research-* (Reddit + X via endpoint-uri compatibile)
# Cheia ta de la https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- xAI (Grok) ---
# Folosit de: research-trending (X/Twitter search + trend analysis)
# Cheia ta de la https://console.x.ai
XAI_API_KEY=

# --- YouTube Data API v3 ---
# Folosit de: research-* (channel listings, video metadata, transcripts)
# Cheia ta de la https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=

# --- Anthropic Claude API (direct, in afara Claude Code) ---
# Folosit de: connection-health ping din dashboard (verifica ca ai cheie valida).
# Optional pentru skill-uri custom care apeleaza Claude SDK direct.
# Cheia ta de la https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- WhatsApp Cloud API (Meta) ---
# Folosit de: tool-whatsapp (trimitere mesaje business)
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# Token cu permisiuni `whatsapp_business_messaging` + ID numar telefon Meta Business
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- Google Drive (service account) ---
# Folosit de: tool-drive (citire fisiere din Drive shared cu service account-ul)
# Optiunea 1: path catre fisier JSON al service account-ului (nu pune fisierul in repo)
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
# Optiunea 2 (alternativa): JSON-ul codat base64. Util cand nu vrei fisier extern.
# Genereaza cu: `cat sa.json | base64 -w0` (Linux) sau Convert.ToBase64String (PowerShell)
GOOGLE_DRIVE_SERVICE_ACCOUNT_BASE64=

# ─── Tier: SOCIAL PUBLISHER ─────────────────────────────────────────────────
# Cheile de mai jos sunt necesare DOAR daca ai activat tier-ul Social Publisher
# la onboarding. Pot fi adaugate ulterior.

# --- Zernio (social media posting + analytics) ---
# Folosit de: tool-zernio-social, tool-publisher, tool-video-upload,
#             mkt-short-form-posting, mkt-youtube-content-package, mkt-content-analytics
# Setup: cont gratis la https://zernio.com → Dashboard → API Keys
# Cere connect-accounts in Zernio inainte de a posta (LinkedIn, IG, TikTok, etc.)
ZERNIO_API_KEY=

# ─── Tier: CONTENT CREATOR ──────────────────────────────────────────────────

# --- Groq (rapid Whisper transcription, optional alternative la WhisperX local) ---
# Folosit de: tool-transcription (--backend groq, optional speed boost)
# Cheia ta de la https://console.groq.com (free tier generos)
GROQ_API_KEY=

# --- ScreenshotOne (web screenshots cloud, optional) ---
# Folosit de: tool-web-screenshot (rapid + bot bypass cand setat)
# Fallback automat la Playwright local cand cheia lipseste
# Cheia ta de la https://screenshotone.com
SCREENSHOTONE_API_KEY=

# --- Google Gemini (image generation, optional alternative la GPT) ---
# Folosit de: viz-image-gen (Gemini 3 Pro Image)
# Cheia ta de la https://ai.google.dev (free tier)
GEMINI_API_KEY=

# ─── Tier: RESEARCHER ───────────────────────────────────────────────────────
# Cheile de mai jos activeaza features avansate in skill-urile existente.

# --- Apify (LinkedIn scraping) ---
# Folosit de: tool-linkedin-scraper
# Cost: ~$2 per 1,000 posts (free tier: 2,500 scrapes/luna)
# Cheia ta de la https://apify.com → Settings → Integrations
APIFY_API_KEY=


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ DISTRIBUTION — DOAR daca distribui robOS comercial (autor). Studentul     │
# │ care cumpara robOS lasa toata sectiunea asta GOALA.                       │
# └─────────────────────────────────────────────────────────────────────────────┘

# --- Cloudflare (worker pentru licensing + DNS) ---
# Account ID — vezi via `wrangler whoami`
CLOUDFLARE_ACCOUNT_ID=
# API Token — scopes: Workers, D1, R2, KV, DNS
# Generare: dashboard CF → My Profile → API Tokens → Create Token
CLOUDFLARE_API_TOKEN=
# Zone ID pentru domeniul tau (auto-detectabil de wrangler dupa login)
CLOUDFLARE_ZONE_ID=

# --- Domain (pentru distributie robOS) ---
DOMAIN_PRIMARY=
DOMAIN_API=
DOMAIN_ADMIN=

# --- Admin contact ---
ADMIN_EMAIL=

# --- License internal API (intre app-ul de plata extern si robOS licensing worker) ---
# Token shared. App-ul de plata face POST la /internal/licenses/create cu acest header.
LICENSE_INTERNAL_API_TOKEN=

# --- Email transactional ---
# Worker NU trimite email. Payment app extern primeste download_url in response
# si trimite welcome email via SMTP propriu. Templates de referinta:
# licensing/src/lib/email.js (welcomeEmail).

# --- License signing (Ed25519) ---
# Cheile efective ca fisiere PEM in data/keys/ (gitignored).
# Privata = upload via `wrangler secret put` la Cloudflare Worker.
# Publica = embedded in scripts/license-check.js
LICENSE_JWT_PRIVATE_KEY_PATH=data/keys/jwt-private.pem
LICENSE_JWT_PUBLIC_KEY_PATH=data/keys/jwt-public.pem

# --- GitHub (RESERVED for future tarball builds via Actions) ---
# Nu sunt citite de niciun cod actual. Lasate aici ca placeholders pentru
# integrare GitHub Actions cand vei configura un build pipeline.
# GITHUB_TOKEN=
# GITHUB_REPO=
