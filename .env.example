# Configurare robOS Environment
# Copiaza in .env si completeaza cheile

# === Dashboard ===
# Port pentru Command Centre (web UI)
PORT=3001

# === Web Scraping ===
# Folosit de skills-urile de research sa crawl-eze si sa extraga continut web
# Cheia ta de la https://firecrawl.dev
FIRECRAWL_API_KEY=

# === OpenAI ===
# Folosit pentru research Reddit si X/Twitter prin endpoint-uri compatibile
OPENAI_API_KEY=

# === xAI (Grok) ===
# Folosit pentru cautare X/Twitter si analiza trenduri
# Cheia ta de la https://console.x.ai
XAI_API_KEY=

# === YouTube Data API ===
# Folosit pentru listare canale, metadata video, descarcare transcript
# Cheia ta de la https://console.cloud.google.com
YOUTUBE_API_KEY=

# === Google Gemini ===
# Folosit pentru generare imagini in skills-urile de content
# Cheia ta de la https://aistudio.google.com
GEMINI_API_KEY=

# === WhatsApp Cloud API ===
# Folosit de skill-ul tool-whatsapp pentru a trimite mesaje
# Setup: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# === Google Drive (service account) ===
# Folosit de skill-ul tool-drive pentru a citi fisiere din Drive
# Optiunea 1: path catre fisierul JSON al service account-ului
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
# Optiunea 2 (alternativa): JSON-ul codat base64 (util cand nu vrei fisier extern)
GOOGLE_DRIVE_SERVICE_ACCOUNT_BASE64=
