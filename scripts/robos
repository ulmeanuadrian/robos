#!/usr/bin/env bash
# robOS launcher — bash wrapper. Delega la node scripts/robos.js
set -euo pipefail

OS="$(uname -s 2>/dev/null || echo unknown)"

# Node check
if ! command -v node >/dev/null 2>&1; then
    echo "EROARE: Node.js nu e instalat. robOS necesita Node >= 22.12.0." >&2
    case "$OS" in
        Darwin) echo "Ruleaza: brew install node" >&2 ;;
        Linux)  echo "Ruleaza: curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - && sudo apt install -y nodejs" >&2 ;;
        *)      echo "Descarca de la: https://nodejs.org" >&2 ;;
    esac
    echo "Dupa instalare, deschide o fereastra noua de terminal si reincearca." >&2
    exit 1
fi

NODE_VERSION=$(node -v | sed 's/^v//')
NODE_MAJOR=$(echo "$NODE_VERSION" | cut -d. -f1)
NODE_MINOR=$(echo "$NODE_VERSION" | cut -d. -f2)
NODE_TOO_OLD=0
if [ "$NODE_MAJOR" -lt 22 ]; then
    NODE_TOO_OLD=1
elif [ "$NODE_MAJOR" -eq 22 ] && [ "$NODE_MINOR" -lt 12 ]; then
    NODE_TOO_OLD=1
fi
if [ "$NODE_TOO_OLD" -eq 1 ]; then
    echo "EROARE: Node.js $(node -v) e prea vechi. robOS necesita Node >= 22.12.0 (Astro)." >&2
    case "$OS" in
        Darwin) echo "Upgrade: brew install node && brew link --overwrite node" >&2 ;;
        Linux)  echo "Upgrade: curl -fsSL https://deb.nodesource.com/setup_22.x | sudo -E bash - && sudo apt install -y nodejs" >&2 ;;
        *)      echo "Descarca LTS de la: https://nodejs.org" >&2 ;;
    esac
    exit 1
fi

# Claude Code CLI check
if ! command -v claude >/dev/null 2>&1; then
    echo "EROARE: Claude Code CLI nu e instalat. robOS ruleaza prin Claude Code." >&2
    echo "Ruleaza: curl -fsSL https://claude.ai/install.sh | sh" >&2
    echo "Dupa instalare, deschide o fereastra noua de terminal si reincearca." >&2
    exit 1
fi

exec node "$(cd "$(dirname "$0")" && pwd)/robos.js" "$@"
