# Internal (not distributed to customers)
.internal/

# User data (never overwritten by updates)
# Brand files are templates -- track them, but users customize locally
# Use git update-index --skip-worktree brand/*.md to stop tracking local edits
context/USER.md
context/learnings.md
context/learnings/
context/memory/
context/decision-journal.md
context/audits/*.md
!context/audits/.gitkeep
projects/*
!projects/.gitkeep
clients/*/
cron/jobs/*
!cron/jobs/.gitkeep
cron/logs/
cron/status/

# Env: ignore all variants except the committed template
.env*
!.env.example

# Second brain notes — operator-authored knowledge (template ships empty)
context/notes/
!context/notes/.gitkeep

# Runtime
.command-centre/
data/
data/*.db
data/*.db-shm
data/*.db-wal
data/.update-staging/
data/.update-backup/
node_modules/
centre/node_modules/
centre/dist/
*.pid

# Build artifacts (tarballs intermediate + final)
licensing/build/

# Logs
*.log
cron/logs/

# Test environments (created by scripts/test-env/new.cmd in user home, but
# also document here in case symlinked)
robos-tests/

# Author-only documentation reference (not for distribution, untracked)
docs/init/

# Archive — local-only graveyard for legacy/vendor leftovers + audit snapshots.
# Used by /archive policy: instead of rm, mv to .archive/{category}/ for safety.
.archive/

# OS
.DS_Store
Thumbs.db
*~
.*.swp

# Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.sublime-workspace
paperclip/robomarketing/

# Claude Code per-user settings (project-level settings.json IS committed)
.claude/settings.local.json
