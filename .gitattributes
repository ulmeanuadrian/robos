# Files/dirs excluded from `git archive` (= excluded from student tarball).
# These remain in the repository for the author but are NOT distributed.
#
# Trigger: licensing/scripts/build-base-tarball.js runs `git archive HEAD`
# which respects export-ignore. Result: a leaner, safer tarball for students.

# Cloudflare Worker source code — author-only (Worker runs at api.robos.vip)
licensing/ export-ignore

# Internal tests with author paths / assumptions
tests/ export-ignore

# Personal scratchpad / brand backups (already in .gitignore but belt-and-braces)
paperclip/ export-ignore

# Internal planning docs (if/when added)
docs/internal/ export-ignore

# Author-only memory and notes (already in .gitignore for tracked content)
# context/notes/ export-ignore  # already gitignored, belt-and-braces redundant

# Line-ending normalization for cross-platform Windows/Mac/Linux students.
# Default: normalize all text to LF in repo. Bash scripts on Mac fail with
# CRLF ("$'\r': command not found"). Windows-specific files get CRLF explicitly.
* text=auto eol=lf

# Windows-specific scripts — keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.db binary
*.tar binary
*.gz binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 binary

# Executable bit preservation: scripts without extension that must be runnable
# on Mac/Linux. git uses index +x bit when core.fileMode=true.
scripts/robos text eol=lf
